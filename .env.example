# PatchMap API — variáveis de ambiente. Copie para .env e ajuste.
#   cp .env.example .env
# O docker-compose.yml (produção) lê estes valores.

# ── Banco (Postgres no docker-compose) ───────────────────────────────
POSTGRES_USER=patchmap
POSTGRES_PASSWORD=TROQUE-esta-senha-em-producao
POSTGRES_DB=patchmap

# Sobrescreve a connection string inteira (opcional). Em dev fora do Docker
# e sem DATABASE_URL, o Django cai para SQLite (db.sqlite3).
# DATABASE_URL=postgresql://patchmap:senha@db:5432/patchmap

# ── Django ───────────────────────────────────────────────────────────
# PRODUÇÃO: mantenha false.
DJANGO_DEBUG=false
# Gere uma chave forte:  python -c "import secrets;print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=TROQUE-por-uma-chave-aleatoria-longa
# Domínio/IP da VM (separado por vírgula). Inclua o IP público ou o domínio.
# 10.0.2.2 é o host visto pelo emulador Android (útil só em dev).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,SEU_IP_OU_DOMINIO
# Se o admin ficar atrás de HTTPS, liste a origem (ex.: https://api.seu-dominio.com)
CSRF_TRUSTED_ORIGINS=

# ── HTTPS / proxy reverso ────────────────────────────────────────────
# Defina true quando houver um proxy (Nginx/Traefik/Caddy) servindo TLS.
# Ativa redirect p/ HTTPS, cookies secure e HSTS.
SECURE_SSL=false

# ── CORS (app mobile não precisa; web/Expo dev sim) ──────────────────
CORS_ALLOW_ALL=true
CORS_ALLOWED_ORIGINS=

# ── Gunicorn / porta ─────────────────────────────────────────────────
GUNICORN_WORKERS=3
BACKEND_PORT=8000

# ── Superusuário semeado (seed_data) ─────────────────────────────────
SEED_ADMIN_EMAIL=admin@patchmap.com
SEED_ADMIN_PASSWORD=TROQUE-esta-senha
