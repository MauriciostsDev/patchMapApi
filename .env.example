# PatchMap API — variáveis de ambiente (copie para .env e ajuste).
# O docker-compose.yml lê estes valores; sem .env, usa os defaults de dev.

# ── Banco (Postgres no docker-compose) ───────────────────────────────
POSTGRES_USER=patchmap
POSTGRES_PASSWORD=patchmap
POSTGRES_DB=patchmap

# Sobrescreve a connection string inteira (opcional). Sem DATABASE_URL e
# rodando fora do Docker, o Django cai para SQLite (db.sqlite3).
# DATABASE_URL=postgresql://patchmap:patchmap@db:5432/patchmap

# ── Django ───────────────────────────────────────────────────────────
DJANGO_DEBUG=true
# DJANGO_SECRET_KEY=troque-isto-em-producao
# 10.0.2.2 = host da máquina visto de dentro do emulador Android
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend,10.0.2.2
CORS_ALLOW_ALL=true

# ── Superusuário semeado (seed_data) ─────────────────────────────────
SEED_ADMIN_EMAIL=admin@patchmap.com
SEED_ADMIN_PASSWORD=123456
